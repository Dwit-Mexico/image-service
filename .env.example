# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...

# Contenedor por defecto cuando el cliente no especifica uno
DEFAULT_CONTAINER=images

# Proyectos — formato: PROJECT_<NOMBRE>=<cert_cn>:<api_key>
# cert_cn debe coincidir con el CN del certificado mTLS del cliente
PROJECT_ALPHA=project-alpha:sk_live_xxxxxxxxxxxxxxxxxxxx
PROJECT_BETA=project-beta:sk_live_yyyyyyyyyyyyyyyyyyyy

# Puerto de escucha (default: 0.0.0.0:8080)
LISTEN_ADDR=0.0.0.0:8080

# Log level
RUST_LOG=info
